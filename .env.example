# MAISON E-commerce — Environment Variables
# Copy to .env.local

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: CMS (Sanity, Contentful, etc.)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production

# Optional: Payment gateway
# VNPAY_TMN_CODE=
# VNPAY_HASH_SECRET=
# MOMO_PARTNER_CODE=
# MOMO_ACCESS_KEY=
